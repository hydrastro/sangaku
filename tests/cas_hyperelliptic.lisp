(import "cas/hyperelliptic.lisp")
(define q5 (list 1 0 0 0 0 1))
(define q6 (list 1 0 0 0 0 0 1))
(display (he-genus q5)) (display " ") (display (he-genus q6)) (newline)
(define r1 (he-integrate (list 0 0 0 0 (/ 5 2)) q5))
(display (he-certify (list 0 0 0 0 (/ 5 2)) q5 r1)) (newline)
(display (car (he-integrate (list 1) q5))) (newline)
(display (car (he-integrate (list 0 1) q5))) (newline)
(display (car (he-integrate (list 1) q6))) (newline)
(define r6 (he-integrate (list 0 0 0 0 0 3) q6))
(display (he-certify (list 0 0 0 0 0 3) q6 r6)) (newline)
(display (car (he-split (list 1 0 0 0 0 1) q5))) (newline)
