(display (idt-equal? (idt-sym (V 1) (V 0) (V 0) (idt-refl (V 1) (V 0))) (idt-refl (V 1) (V 0)))) (newline)
(define ctxT (list (list (quote app) (V 3) (V 2)) (idt-Id (V 3) (V 1) (V 0)) (V 2) (V 1) (list (quote pi) (V 0) (quote type)) (quote type)))
(display (idt-equal? (idt-infer ctxT (idt-transport (V 5) (V 4) (V 3) (V 2) (V 1) (V 0))) (list (quote app) (V 4) (V 2)))) (newline)
(display (idt-equal? (idt-transport (V 3) (V 2) (V 1) (V 1) (idt-refl (V 3) (V 1)) (V 0)) (V 0))) (newline)
