(define ctxAa (list (V 0) (quote type)))
(display (idt-equal? (idt-infer ctxAa (idt-Id (V 1) (V 0) (V 0))) (quote type))) (newline)
(display (idt-check ctxAa (idt-refl (V 1) (V 0)) (idt-Id (V 1) (V 0) (V 0)))) (newline)
(define A1 (V 1))
(define motive (list (quote lam) A1 (list (quote lam) (idt-shift 1 0 A1) (list (quote lam) (idt-Id (idt-shift 2 0 A1) (V 1) (V 0)) (idt-Id (idt-shift 3 0 A1) (V 2) (V 2))))))
