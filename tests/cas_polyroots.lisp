(import "cas/polyroots.lisp")
(define f1 (list (cons 1 (list 2 0)) (cons 1 (list 0 2)) (cons -1 (list 0 0))))
(define f2 (list (cons 1 (list 1 0)) (cons -1 (list 0 1))))
(define S1 (list f1 f2))
(display (pr-eliminant->coeffs (psys-eliminant S1 2 1) 1 2)) (newline)
(display (pr-real-solution-count S1 2 1)) (newline)
(display (pr-real-intervals S1 2 1 (/ 1 100))) (newline)
(define e1 (list (cons 1 (list 1 0 0)) (cons -1 (list 0 0 0))))
(define e2 (list (cons 1 (list 0 1 0)) (cons -2 (list 0 0 0))))
(define e3 (list (cons 1 (list 0 0 1)) (cons -3 (list 0 0 0))))
(define S4 (list e1 e2 e3))
(display (pr-real-solution-count S4 3 0)) (display " ") (display (pr-real-solution-count S4 3 2)) (newline)
(display (pr-solution-report S1 2 (/ 1 100))) (newline)
